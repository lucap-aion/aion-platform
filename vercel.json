{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "rc.app.aioncover.com" }],
      "destination": "https://app.aioncover.com/rc/:path*",
      "permanent": false
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
